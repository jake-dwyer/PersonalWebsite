# Server-side Oura Ring Personal Access Token consumed by the proxy/API route.
# Generate at https://cloud.ouraring.com/personal-access-tokens and keep this secret.
OURA_API_TOKEN=your_oura_token_here

# Passphrase required to unlock the private dashboard view.
# Visitors must enter this string; keep it short but unique.
OURA_DASHBOARD_PASSWORD=choose_a_password
