# Server-side Oura credentials (choose ONE option).

# Option 1: Legacy personal access token (deprecated end of 2025)
# Generate at https://cloud.ouraring.com/personal-access-tokens
OURA_API_TOKEN=

# Option 2: OAuth client credentials + refresh token (preferred)
# Leave OURA_API_TOKEN blank to use these instead.
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REFRESH_TOKEN=

# Passphrase required to unlock the private dashboard view.
# Visitors must enter this string; keep it short but unique.
OURA_DASHBOARD_PASSWORD=
